# ==========================================================================
# Blufire — environment variables (per-install, NEVER commit your real .env)
# Copy to: $BLUFIRE_HOME/.env  or  /etc/blufire/<tenant>.env
# ==========================================================================

# --- Tenant identity ------------------------------------------------------
BLUFIRE_TENANT_ID=
BLUFIRE_HOME=

# --- Required API keys ----------------------------------------------------
HUBSPOT_API_KEY=
ANTHROPIC_API_KEY=
APOLLO_API_KEY=

# --- Email (Gmail SMTP) ---------------------------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Outbound webhooks ----------------------------------------------------
# Optional: only set if you draft via Make.com (or another webhook receiver)
MAKE_DRAFT_WEBHOOK_URL=

# --- Compliance -----------------------------------------------------------
# Public base URL where the unsubscribe endpoint is reachable
UNSUBSCRIBE_BASE_URL=

# --- Licensing (Phase 2; placeholder for now) -----------------------------
BLUFIRE_LICENSE_KEY=

# --- Optional ops integrations --------------------------------------------
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
