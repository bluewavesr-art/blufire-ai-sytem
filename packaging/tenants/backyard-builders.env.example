# Blufire secrets for the Backyard Builders tenant.
# Install path: /etc/blufire/backyard-builders.env  (mode 0640 root:blufire)

# Required
ANTHROPIC_API_KEY="sk-ant-..."

# Google Places API key — enable "Places API (New)" + "Maps JavaScript API"
# in the same GCP project, then create an API key. Restrict it to the
# Places API only and (optionally) to your VPS's outbound IP.
GOOGLE_PLACES_API_KEY="..."

# Service-account JSON for Google Sheets API access. Generate in GCP
# Console → IAM → Service Accounts → create key (JSON). Share both the
# Leads, Drafts, and Call List worksheets with the service-account email
# (<sa-name>@<project>.iam.gserviceaccount.com) with Editor permission.
GSHEETS_CREDENTIALS_PATH="/etc/blufire/backyard-builders.gsheets.json"

# Not used for this tenant (no SMTP send), but the Settings model still
# requires gmail_user/gmail_app_password to be set *if* email.provider is
# "gmail". You can leave them blank since we never actually send — the
# email_outreach SMTP path isn't invoked.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Optional — only if you stand up the unsubscribe server publicly
UNSUBSCRIBE_BASE_URL=""

# Optional — Sentry for error reporting
# SENTRY_DSN=""
